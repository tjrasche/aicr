# UAT runner (GCP/GKE). Thin shim over tests/uat/lib/phases.sh, which holds the
# cloud-agnostic phase implementations and the phase dispatcher. Codifies the
# workflow demonstrated in demos/cuj1-gke-config.md and is invoked phase-by-phase
# from .github/workflows/uat-gcp.yaml so per-phase failures surface in the
# GitHub Actions UI. GKE needs no cloud-specific overrides: the workload-identity
# session outlasts each phase, and the workflow refreshes it before teardown.
#
# Usage:
#   AICR_BIN=./aicr RUN_ID=12345 ./run <phase> <test-config.yaml>
# See tests/uat/lib/phases.sh for the phase list and the working files produced.

set -euo pipefail

# shellcheck source=../lib/phases.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/phases.sh"

uat_main "$@"
