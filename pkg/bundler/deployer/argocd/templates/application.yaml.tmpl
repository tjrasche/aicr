apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ printf "%q" .Name }}
  namespace: argocd
  annotations:
    argocd.argoproj.io/sync-wave: "{{ .SyncWave }}"
{{- if .CascadeDelete }}
  finalizers:
    - resources-finalizer.argocd.argoproj.io
{{- end }}
spec:
  project: {{ printf "%q" .Project }}
{{- if .IsLocalChart }}
  source:
    repoURL: '{{ .RepoURL }}'
    targetRevision: {{ .TargetRevision }}
    path: {{ .BundleDir }}
{{- else if .InlineValues }}
  source:
    repoURL: {{ .Repository }}
    chart: {{ .Chart }}
    targetRevision: {{ .Version }}
    helm:
      valuesObject:
{{ .ValuesYAML -}}
{{- else }}
  sources:
    - repoURL: {{ .Repository }}
      chart: {{ .Chart }}
      targetRevision: {{ .Version }}
      helm:
        valueFiles:
          - $values/{{ .BundleDir }}/values.yaml
    - repoURL: '{{ .RepoURL }}'
      targetRevision: {{ .TargetRevision }}
      ref: values
{{- end }}
  destination:
    server: {{ printf "%q" .DestinationServer }}
    namespace: {{ printf "%q" .Namespace }}
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      # ServerSideApply: enabled uniformly across all generated
      # Applications. Required for charts whose CRDs exceed kubectl's
      # 262144-byte client-side annotation cap (e.g.,
      # kube-prometheus-stack, kai-scheduler) — otherwise Argo's sync
      # retries forever with "metadata.annotations: Too long". The
      # apiserver's structured-merge path has no such cap. Benign on
      # Applications that don't need it (pre-folder Namespaces,
      # post-folder ConfigMaps) — keeping it on every Application avoids
      # per-Application template branching and a confusing mix of sync
      # strategies in a single bundle.
      - ServerSideApply=true
